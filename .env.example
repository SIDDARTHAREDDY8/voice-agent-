# Copy this file to `.env` and paste your key. `.env` is gitignored — never commit it.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional model overrides:
# MODEL_AGENT=claude-sonnet-5
# MODEL_SIM=claude-haiku-4-5-20251001

# Real human-sounding voices for voice.py. Get a key at
# https://elevenlabs.io/app/settings/api-keys (free tier included).
# Without it, voice.py falls back to the offline macOS `say` voice.
# ELEVENLABS_API_KEY=sk_your-elevenlabs-key-here

# Optional voice overrides (default: Sarah for the agent, Aria for the payer).
# Browse voice IDs at https://elevenlabs.io/app/voice-library
# ELEVEN_VOICE_AGENT=EXAVITQu4vr4xnSDxMaL
# ELEVEN_VOICE_PAYER=9BWtsMINqrJLrRacOk9x
# ELEVEN_MODEL=eleven_multilingual_v2
